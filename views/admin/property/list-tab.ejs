<div class="card shadow mb-4">
    <div class="card-body mt-2">
        <div class="table-responsive">
            <table
                class="table table-bordered"
                id="dataTable"
                width="100%"
                cellspacing="0"
            >
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Name</th>
                        <th>Price ($)</th>
                        <th>Country</th>
                        <th>City</th>
                        <th>Popular</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% property.forEach((item, index) => { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= item.name %></td>
                            <td><%= item.price %></td>
                            <td><%= item.country %></td>
                            <td><%= item.city %></td>
                            <td><%= item.isPopular ? `Yes` : `No` %></td>
                            <td>
                                <a href="/admin/properties/<%= item._id %>" class="btn btn-sm btn-info">
                                    Edit
                                </a>
                                <form action="/admin/properties/<%= item._id %>?_method=DELETE" method="POST" style="display: inline;">
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        Delete
                                    </button>
                                </form>
                                <a href="/admin/properties/images/<%= item._id %>" class="btn btn-sm btn-primary">
                                    Images
                                </a>
                                <a href="/admin/properties/show/<%= item._id %>" class="btn btn-sm btn-success">
                                    Detail
                                </a>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>
